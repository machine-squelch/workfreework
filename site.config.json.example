{
  "site": {
    "name": "My Startup",
    "domain": "mystartup.com",
    "tagline": "The future of work",
    "description": "A longer description for SEO and social sharing"
  },
  "theme": {
    "colors": {
      "primary": "#A6FF00",
      "accent": "#FF3B3F",
      "background": "#F5F5F0",
      "text": "#000000"
    },
    "fonts": {
      "heading": "Space Grotesk",
      "body": "Space Grotesk"
    },
    "style": {
      "mode": "auto",
      "neonGlow": true,
      "glassMorphism": true,
      "animations": true
    }
  },
  "pages": {
    "enabled": ["home", "about", "blog", "contact"],
    "disabled": [],
    "custom": []
  },
  "features": {
    "emailCapture": {
      "enabled": true,
      "provider": "convertkit",
      "apiKey": "env:CONVERTKIT_API_KEY",
      "formId": "env:CONVERTKIT_FORM_ID"
    },
    "payments": {
      "enabled": false,
      "provider": "stripe",
      "apiKey": "env:STRIPE_SECRET_KEY",
      "priceIds": {
        "builder": "env:STRIPE_PRICE_ID_BUILDER",
        "operator": "env:STRIPE_PRICE_ID_OPERATOR",
        "accelerator_cohort": "env:STRIPE_PRICE_ID_ACCELERATOR_COHORT",
        "accelerator_dfy": "env:STRIPE_PRICE_ID_ACCELERATOR_DFY",
        "collective": "env:STRIPE_PRICE_ID_COLLECTIVE",
        "accelerator": "env:STRIPE_PRICE_ID_ACCELERATOR",
        "patron": "env:STRIPE_PRICE_ID_PATRON"
      }
    },
    "aiChatbot": {
      "enabled": false,
      "provider": "anthropic",
      "apiKey": "env:ANTHROPIC_API_KEY",
      "model": "claude-3-haiku-20240307",
      "persona": "You are a helpful assistant."
    },
    "video": {
      "enabled": false,
      "provider": "manual",
      "apiKey": "env:GEMINI_API_KEY",
      "note": "Gemini API in beta - use manual uploads for now"
    }
  },
  "content": {
    "essays": {
      "enabled": true,
      "path": "/essays",
      "defaultContent": []
    },
    "tools": {
      "enabled": false,
      "path": "/tools"
    },
    "blog": {
      "enabled": false,
      "path": "/blog"
    }
  },
  "seo": {
    "defaultTitle": "My Startup",
    "defaultDescription": "A longer description for SEO and social sharing",
    "ogImage": "/og-image.png",
    "favicon": "/favicon.ico"
  },
  "deployment": {
    "platform": "vercel",
    "autoDeploy": false,
    "previewDeploy": true
  }
}
